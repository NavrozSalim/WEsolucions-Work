# Production — copy to `.env.prod` (gitignored).
# Build frontend: cd frontend && VITE_API_URL=/api/v1 npm run build
# Start: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

POSTGRES_DB=saas_sync
POSTGRES_USER=saas
POSTGRES_PASSWORD=navo123

DEBUG=False
# Gunicorn is HTTP behind nginx; 0 avoids 301 on internal /health/ (Docker healthcheck).
SECURE_SSL_REDIRECT=0
DOMAIN_NAME=wesolucions.com
# Add YOUR_SERVER_IPV4,backend if you open the site by IP or use Docker internal name
ALLOWED_HOSTS=wesolucions.com,www.wesolucions.com,173.212.218.31,backend
CORS_ALLOWED_ORIGINS=https://wesolucions.com,https://www.wesolucions.com,http://wesolucions.com,http://www.wesolucions.com,http://173.212.218.31,https://173.212.218.31

JWT_SECRET=5b7d71019d7861a5186d8560fb74c9efaab1b9402e02857625ff868aaba156f0
ENCRYPTION_KEY=e5cpWPbyFP_O37M2J6xRwcQjQPZWCyEUcBzKAmtHuNQ=


GOOGLE_CLIENT_ID=813956020745-r7nmrlu4m5rrmm5re6bk8ah5m06kd5kb.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=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
GOOGLE_REDIRECT_URI=https://wesolucions.com/api/v1/auth/google/callback/


VITE_API_URL=/api/v1

# eBay scraper: 0 = Selenium-first (recommended on VPS/datacenter). 1 = try HTTP (curl_cffi) before browser.
# EBAY_HTTP_FIRST=0

# Gunicorn worker timeout (seconds). Keep long jobs on Celery; raise only if needed for other endpoints.
# GUNICORN_TIMEOUT=120

# Store-wide scrape in the web worker: leave unset (off when DEBUG=False). Set 1 only for emergency debugging — prefer Celery.
# CATALOG_ALLOW_INLINE_STORE_WIDE_SCRAPE=0

# Optional: pre-built backend image for backend + celery (skip docker compose build)
# BACKEND_IMAGE=youruser/saas-store-sync-backend:latest
# Optional: published ports
# HTTP_PORT=80
# HTTPS_PORT=443

# HEB Selenium scraper (optional). Precedence: PROXY_URLS > PROXY_ENDPOINTS > PROXY_URL > PROXY_HOST+PORT.
# Multiple proxies: round-robin on each new Chrome session (including retries / driver recreate).
#
# Option A — one URL per entry (comma or newline):
# PROXY_URLS=http://user:pass@host1:port1,http://user:pass@host2:port2
#
# Option B — shared login, many host:port (comma or newline):
# PROXY_ENDPOINTS=host1:port1,host2:port2,host3:port3
# PROXY_USER=
# PROXY_PASS=
# PROXY_SCHEME=http
#
# Optional: HEB via Apify actor (HEB only; other vendors unchanged).
# HEB_USE_APIFY=1
# HEB_APIFY_TOKEN=apify_api_xxx
# HEB_APIFY_ACTOR_ID=your-user-or-org/heb-scraper
# HEB_APIFY_TIMEOUT_SEC=90

# Costco AU scraper (Cloudflare-protected).
# Prefer dedicated residential AU proxies instead of generic PROXY_URLS.
# COSTCO_AU_PROXY_URL=http://user:pass@host:port
# COSTCO_AU_PROXY_URLS=http://user:pass@host1:port1,http://user:pass@host2:port2
#
# Keep request cadence low to reduce captcha/ban pressure.
# COSTCO_AU_MIN_REQUEST_GAP_SEC=20
# COSTCO_AU_LOCK_WAIT_SEC=120
#
# Single proxy (unchanged):
# PROXY_URL=http://user:pass@host:port
# PROXY_HOST=
# PROXY_PORT=
# PROXY_USER=
# PROXY_PASS=
# PROXY_SCHEME=http

# Walmart Marketplace API v3 (optional defaults; can also be provided per-store via Store.api_token JSON)
# WALMART_CLIENT_ID=
# WALMART_CLIENT_SECRET=
# WALMART_CONSUMER_ID=
# WALMART_CHANNEL_TYPE=
# WALMART_PRIVATE_KEY_PEM="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----"
