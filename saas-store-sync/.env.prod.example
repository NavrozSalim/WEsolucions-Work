# Production — copy to `.env.prod` (gitignored).
# Build frontend: cd frontend && VITE_API_URL=/api/v1 npm run build
# Start: docker compose -f docker-compose.prod.yml --env-file .env.prod up -d

POSTGRES_DB=saas_sync
POSTGRES_USER=saas
POSTGRES_PASSWORD=replace_with_strong_password

DEBUG=False
DOMAIN_NAME=your-domain.com
ALLOWED_HOSTS=your-domain.com,www.your-domain.com
CORS_ALLOWED_ORIGINS=https://your-domain.com,https://www.your-domain.com
FRONTEND_URL=https://your-domain.com

JWT_SECRET=replace_with_random_secret
ENCRYPTION_KEY=replace_with_fernet_key

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-domain.com/api/v1/auth/google/callback/

VITE_API_URL=/api/v1
