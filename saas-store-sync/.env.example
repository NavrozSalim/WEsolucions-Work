# Development — copy to `.env` in this folder (gitignored).
# Start stack: docker compose up -d

POSTGRES_DB=saas_sync
POSTGRES_USER=saas
POSTGRES_PASSWORD=change_me_strong_password

POSTGRES_PORT=5433
REDIS_PORT=6379
BACKEND_PORT=8000
FRONTEND_PORT=3001

REDIS_URL=redis://localhost:6379/0

DEBUG=True
JWT_SECRET=replace_with_random_hex_or_string
ALLOWED_HOSTS=localhost,127.0.0.1,backend
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://127.0.0.1:3000,http://127.0.0.1:3001
FRONTEND_URL=http://localhost:3001

# python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=replace_with_fernet_key

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8000/api/v1/auth/google/callback/

# Browser hits backend on host port (not docker service name)
VITE_API_URL=http://localhost:8000/api/v1
